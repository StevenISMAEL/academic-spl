# --- Python (backend FastAPI) ---
venv/
.venv/
__pycache__/
*.pyc
.pytest_cache/
coverage.xml

# --- Terraform ---
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
# --- Variables de entorno y secretos: NUNCA se commitean ---
.env
.env.*
!.env.example

# --- gRPC generado: se regenera con protoc, no se versiona ---
**/grpc_contracts/**/generated/
*_pb2.py
*_pb2_grpc.py

# --- Laravel / PHP ---
core_assets/frontend/laravel-shell/vendor/
core_assets/frontend/laravel-shell/node_modules/
core_assets/frontend/laravel-shell/storage/*.key
core_assets/frontend/laravel-shell/bootstrap/cache/*.php
core_assets/frontend/laravel-shell/.env

# --- Productos derivados (derived_products/) ---
# Solo se ignoran los archivos que NO deben subir a git.
# Los product_config.yaml y run_app.py SÍ se versionan
# porque el pipeline CI/CD los necesita para construir las imágenes Docker.

# Secretos y configuración local
derived_products/**/.env
derived_products/**/.env.*
derived_products/**/.env.frontend

# Bases de datos locales de desarrollo
derived_products/**/*.db
derived_products/**/*.sqlite

# La carpeta core_engine es una copia de core_assets/ — no duplicar en git
derived_products/**/core_engine/

# Caché de Python
derived_products/**/__pycache__/
derived_products/**/*.pyc

# --- Editor / Sistema operativo ---
.vscode/
Thumbs.db
desktop.ini
.DS_Store

# --- Temporales ---
*.log