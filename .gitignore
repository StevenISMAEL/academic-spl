# --- Python (backend FastAPI) ---
venv/
__pycache__/
*.pyc
.pytest_cache/

# --- Variables de entorno y secretos: NUNCA se commitean ---
.env
.env.*
!.env.example

# --- gRPC generado: se regenera con protoc, no se versiona ---
**/grpc_contracts/**/generated/
*_pb2.py
*_pb2_grpc.py

# --- Laravel / PHP ---
core_assets/frontend/laravel-shell/vendor/
core_assets/frontend/laravel-shell/node_modules/
core_assets/frontend/laravel-shell/storage/*.key
core_assets/frontend/laravel-shell/bootstrap/cache/*.php
core_assets/frontend/laravel-shell/.env

# --- Bases de datos locales de cada producto derivado ---
products/**/*.sqlite
products/**/*.db
derived_products/

# --- Editor / Sistema operativo ---
.vscode/
Thumbs.db
desktop.ini
.DS_Store

# --- Temporales ---
*.log